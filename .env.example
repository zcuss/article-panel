# Auth
ADMIN_PASSWORD=changeme
JWT_SECRET=replace-with-random-32-char-secret

# AI (OpenAI-compatible)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-xxx
AI_MODEL=gpt-4o-mini
# Optional: custom header e.g. "HTTP-Referer: https://yoursite.com" for OpenRouter
AI_EXTRA_HEADER=

# Output paths (server)
SITES_DIR=./public/sites
NGINX_SITES_DIR=./nginx/sites
NGINX_INCLUDE_PATH=/etc/nginx/sites-enabled/articles.conf
NGINX_RELOAD_CMD=sudo /usr/sbin/nginx -s reload
